@model IEnumerable<BlindMatchPAS.ViewModels.AdminUserRow>

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-white fw-bold">User Management</h1>
        <a href="/Admin/CreateUser" class="btn btn-primary" style="background-color: #bbf706; color: black; border: none; font-weight: bold;">
            + Create New User
        </a>
    </div>

    <div class="card bg-dark border-0 shadow">
        <div class="card-body p-0">
            <table class="table table-hover table-dark mb-0">
                <thead style="background-color: #1a202c;">
                    <tr>
                        <th class="border-0 px-4 py-3">Full Name</th>
                        <th class="border-0 py-3">Email</th>
                        <th class="border-0 py-3">Role</th>
                        <th class="border-0 py-3">Status</th>
                        <th class="border-0 px-4 py-3 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="px-4 py-3">System Test User</td>
                        <td>test@university.com</td>
                        <td><span class="badge bg-secondary">Student</span></td>
                        <td><span class="text-success">● Active</span></td>
                        <td class="px-4 py-3 text-end">
                            <button class="btn btn-sm btn-outline-light border-0">Edit</button>
                        </td>
                    </tr>
                    </tbody>
            </table>
        </div>
    </div>
</div>