@model IEnumerable<BlindMatchPAS.ViewModels.AdminUserRow>

@{
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <div>
        <h1 class="page-title">User <span class="accent-text">Management</span></h1>
        <p class="page-subtitle">Create, edit, and manage system users and their roles.</p>
    </div>
    <a asp-action="CreateUser" class="btn-primary">
        + Create New User
    </a>
</div>

<!-- Users Table -->
<div class="content-card">
    <div class="card-header">
        <h2 class="card-title">All Users</h2>
    </div>

    @if (Model.Any())
    {
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="user-name" style="font-weight: 500;">@user.FullName</div>
                            </td>
                            <td style="color: #aaaaaa; font-size: 13px;">@user.Email</td>
                            <td>
                                <span class="role-badge" style="background-color: #6b7280; color: white; padding: 4px 12px; border-radius: 4px; font-size: 12px;">
                                    @user.Role
                                </span>
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span style="color: #22c55e; font-weight: 500;">● Active</span>
                                }
                                else
                                {
                                    <span style="color: #ef4444; font-weight: 500;">● Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="EditUser" asp-route-id="@user.UserId" class="btn-sm btn-primary">
                                        <i class="fa-solid fa-pen-to-square"></i> Edit
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fa-solid fa-users empty-icon"></i>
            <h3 class="empty-title">No Users Found</h3>
            <p class="empty-desc">Start by creating a new user account.</p>
            <a asp-action="CreateUser" class="btn-primary">+ Create New User</a>
        </div>
    }
</div>