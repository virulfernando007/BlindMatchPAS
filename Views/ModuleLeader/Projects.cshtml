<h2>All Projects</h2>

<table style="width:100%; border-collapse: collapse; margin-top:20px;">
    <tr style="background-color:#222; color:white;">
        <th style="padding:10px;">Title</th>
        <th style="padding:10px;">Status</th>
        <th style="padding:10px;">Action</th>
    </tr>

    @foreach (var project in Model)
    {
        <tr style="text-align:center; border-bottom:1px solid #444;">
            <td style="padding:10px;">@project.Title</td>
            <td style="padding:10px;">@project.Status</td>

            <td style="padding:10px;">
                @if (project.Status == "Pending")
                {
                    <a href="/ModuleLeader/Approve?title=@project.Title" style="color:#4CAF50;">Approve</a>
                    <span> | </span>
                    <a href="/ModuleLeader/Reject?title=@project.Title" style="color:#f44336;">Reject</a>
                }
                else
                {
                    <span style="color:gray;">-</span>
                }
            </td>
        </tr>
    }
</table>