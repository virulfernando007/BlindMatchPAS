@{
    ViewData["Title"] = "Dashboard";
}

<h2>Module Leader Dashboard</h2>

<div style="display:flex; gap:20px;">

    <div style="border:1px solid black; padding:15px;">
        <h3>@ViewBag.TotalProjects</h3>
        <p>Total Projects</p>
    </div>

    <div style="border:1px solid black; padding:15px;">
        <h3>@ViewBag.TotalMatches</h3>
        <p>Total Matches</p>
    </div>

    <div style="border:1px solid black; padding:15px;">
        <h3>@ViewBag.PendingProjects</h3>
        <p>Pending Projects</p>
    </div>

    <div style="border:1px solid black; padding:15px;">
        <h3>@ViewBag.TotalUsers</h3>
        <p>Total Users</p>
    </div>

</div>