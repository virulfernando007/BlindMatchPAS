@{
    ViewData["Title"] = "Module Leader Dashboard";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Module Leader <span class="accent-text">Dashboard</span></h1>
        <p class="page-subtitle">Overview of projects and supervision activities.</p>
    </div>
</div>

<!-- Stat Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-number">@ViewBag.TotalProjects</div>
        <div class="stat-label">Total Projects</div>
    </div>
    <div class="stat-card">
        <div class="stat-number" style="color:#a0aec0">@ViewBag.TotalMatches</div>
        <div class="stat-label">Total Matches</div>
    </div>
    <div class="stat-card">
        <div class="stat-number" style="color:#f59e0b">@ViewBag.PendingProjects</div>
        <div class="stat-label">Pending Projects</div>
    </div>
    <div class="stat-card">
        <div class="stat-number" style="color:#22c55e">@ViewBag.TotalUsers</div>
        <div class="stat-label">Total Users</div>
    </div>
</div>