@model BlindMatchPAS.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "_Layout";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Change <span class="accent-text">Password</span></h1>
        <p class="page-subtitle">Keep your account secure with a strong password.</p>
    </div>
    <a asp-controller="Student" asp-action="Profile" class="btn-outline">← Back to Profile</a>
</div>

<div class="cp-layout">

    <!-- Left info card -->
    <div class="cp-sidebar">
        <div class="form-section-card">
            <div class="form-section-title">Password Requirements</div>
            <div class="cp-req-list">
                <div class="cp-req-item" id="req-length">
                    <span class="cp-req-icon"><i class="fa-solid fa-circle-xmark"></i></span>
                    <span>At least 6 characters</span>
                </div>
                <div class="cp-req-item" id="req-upper">
                    <span class="cp-req-icon"><i class="fa-solid fa-circle-xmark"></i></span>
                    <span>One uppercase letter</span>
                </div>
                <div class="cp-req-item" id="req-number">
                    <span class="cp-req-icon"><i class="fa-solid fa-circle-xmark"></i></span>
                    <span>One number</span>
                </div>
                <div class="cp-req-item" id="req-match">
                    <span class="cp-req-icon"><i class="fa-solid fa-circle-xmark"></i></span>
                    <span>Passwords match</span>
                </div>
            </div>
        </div>

        <div class="form-section-card" style="margin-top:1rem">
            <div class="form-section-title">Security Tips</div>
            <div style="display:flex;flex-direction:column;gap:.75rem;margin-top:.25rem">
                <div style="display:flex;gap:.75rem;align-items:flex-start">
                    <i class="fa-solid fa-shield-halved" style="color:var(--accent);font-size:13px;margin-top:2px;flex-shrink:0"></i>
                    <span style="font-size:13px;color:var(--text-secondary)">Never share your password with anyone</span>
                </div>
                <div style="display:flex;gap:.75rem;align-items:flex-start">
                    <i class="fa-solid fa-key" style="color:var(--accent);font-size:13px;margin-top:2px;flex-shrink:0"></i>
                    <span style="font-size:13px;color:var(--text-secondary)">Use a mix of letters, numbers and symbols</span>
                </div>
                <div style="display:flex;gap:.75rem;align-items:flex-start">
                    <i class="fa-solid fa-rotate" style="color:var(--accent);font-size:13px;margin-top:2px;flex-shrink:0"></i>
                    <span style="font-size:13px;color:var(--text-secondary)">Change your password regularly</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right form -->
    <div class="cp-main">
        <div class="form-section-card">
            <div class="form-section-title">Update Password</div>

            <form asp-controller="Account" asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="validation-summary"></div>

                <!-- Current Password -->
                <div class="form-group">
                    <label asp-for="CurrentPassword" class="form-label">
                        Current Password <span class="required">*</span>
                    </label>
                    <div class="pw-input-wrap">
                        <input asp-for="CurrentPassword"
                               type="password"
                               class="form-input pw-input"
                               placeholder="Enter your current password"
                               id="currentPw" />
                        <button type="button" class="pw-toggle"
                                onclick="togglePw('currentPw', this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="CurrentPassword" class="field-error"></span>
                </div>

                <!-- New Password -->
                <div class="form-group">
                    <label asp-for="NewPassword" class="form-label">
                        New Password <span class="required">*</span>
                    </label>
                    <div class="pw-input-wrap">
                        <input asp-for="NewPassword"
                               type="password"
                               class="form-input pw-input"
                               placeholder="Enter your new password"
                               id="newPw"
                               oninput="checkRequirements()" />
                        <button type="button" class="pw-toggle"
                                onclick="togglePw('newPw', this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NewPassword" class="field-error"></span>

                    <!-- Strength bar -->
                    <div class="pw-strength-wrap">
                        <div class="pw-strength-bar" id="strengthBar"></div>
                    </div>
                    <span class="form-hint" id="strengthLabel">Enter a new password</span>
                </div>

                <!-- Confirm Password -->
                <div class="form-group" style="margin-bottom:0">
                    <label asp-for="ConfirmPassword" class="form-label">
                        Confirm New Password <span class="required">*</span>
                    </label>
                    <div class="pw-input-wrap">
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-input pw-input"
                               placeholder="Confirm your new password"
                               id="confirmPw"
                               oninput="checkRequirements()" />
                        <button type="button" class="pw-toggle"
                                onclick="togglePw('confirmPw', this)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>

                <div class="form-actions" style="margin-top:1.5rem">
                    <a asp-controller="Student" asp-action="Profile" class="btn-outline">
                        Cancel
                    </a>
                    <button type="submit" class="btn-primary">
                        <i class="fa-solid fa-lock"></i> Update Password
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function togglePw(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon  = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fa-solid fa-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'fa-solid fa-eye';
            }
        }

        function checkRequirements() {
            const pw      = document.getElementById('newPw').value;
            const confirm = document.getElementById('confirmPw').value;

            setReq('req-length', pw.length >= 6);
            setReq('req-upper',  /[A-Z]/.test(pw));
            setReq('req-number', /\d/.test(pw));
            setReq('req-match',  pw.length > 0 && pw === confirm);

            updateStrength(pw);
        }

        function setReq(id, pass) {
            const el   = document.getElementById(id);
            const icon = el.querySelector('i');
            if (pass) {
                el.classList.add('cp-req-done');
                icon.className = 'fa-solid fa-circle-check';
            } else {
                el.classList.remove('cp-req-done');
                icon.className = 'fa-solid fa-circle-xmark';
            }
        }

        function updateStrength(pw) {
            const bar   = document.getElementById('strengthBar');
            const label = document.getElementById('strengthLabel');
            let score = 0;
            if (pw.length >= 6)  score++;
            if (pw.length >= 10) score++;
            if (/[A-Z]/.test(pw)) score++;
            if (/\d/.test(pw))    score++;
            if (/[^A-Za-z0-9]/.test(pw)) score++;

            const levels = [
                { w:'0%',   color:'transparent', text:'Enter a new password' },
                { w:'25%',  color:'#ef4444',     text:'Weak' },
                { w:'50%',  color:'#f59e0b',     text:'Fair' },
                { w:'75%',  color:'#3b82f6',     text:'Good' },
                { w:'100%', color:'#22c55e',     text:'Strong' },
            ];
            const lvl = levels[Math.min(score, 4)];
            bar.style.width = lvl.w;
            bar.style.background = lvl.color;
            label.textContent = lvl.text;
            label.style.color = lvl.color === 'transparent'
                ? 'var(--text-muted)' : lvl.color;
        }
    </script>
}