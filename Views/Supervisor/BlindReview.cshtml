@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Blind Review Board";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="mb-1" style="color: var(--text-primary);">Blind Review Board</h2>
        <p style="color: var(--text-secondary);">Evaluate project proposals purely on technical merit. Student identities are protected.</p>
    </div>

    <div class="row g-4">
        @foreach (dynamic project in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="custom-card h-100 d-flex flex-column" style="background: var(--bg-surface); padding: 20px; border-radius: 10px; border: 1px solid var(--border);">
                    
                    <div class="d-flex justify-content-end mb-3">
                        <span class="badge" style="background: var(--bg-elevated); border: 1px solid var(--border); color: var(--accent); padding: 6px 12px;">
                            @project.CompatibilityScore% Match
                        </span>
                    </div>

                    <h5 class="mb-3" style="color: var(--text-primary);">@project.Title</h5>
                    <p style="color: var(--text-secondary); font-size: 14px; flex-grow: 1;">
                        @project.Abstract
                    </p>
                    
                    <div class="mb-4 mt-2">
                        <span style="font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 4px;">Tech Stack</span>
                        <span style="color: var(--accent); font-size: 14px; font-weight: 500;">@project.TechStack</span>
                    </div>

                    <button class="btn w-100 mt-auto" style="background-color: var(--accent); color: #000000; font-weight: 600; border: none; padding: 10px; border-radius: 6px; cursor: pointer;">
                        Express Interest
                    </button>
                </div>
            </div>
        }
    </div>
</div>