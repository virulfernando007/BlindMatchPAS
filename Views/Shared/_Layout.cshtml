<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlindMatch PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
</head>
<body data-toast-success="@TempData["Success"]" data-toast-error="@TempData["Error"]">

    <nav class="sidebar">
        <div class="p-4">
            <a href="/" class="logo-text">BlindMatch<span class="logo-dot">.</span></a>
        </div>
        
        <div class="mt-4">
            @if (User.IsInRole("Admin"))
            {
                <span class="px-4 text-muted" style="font-size: 11px; font-weight: 700; text-transform: uppercase;">Admin Controls</span>
                <a class="sidebar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                <a class="sidebar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Users" ? "active" : "")" asp-controller="Admin" asp-action="Users">Manage Users</a>
                <a class="sidebar-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "MigrationHistory" ? "active" : "")" asp-controller="Admin" asp-action="MigrationHistory">Migration History</a>
            }
            @* Other role blocks (Student, Supervisor, ModuleLeader) will go here later *@
        </div>
    </nav>

    <div class="main-content">
        <header class="top-navbar">
            <div>
                </div>
            <div class="d-flex align-items-center gap-3">
                <button id="theme-toggle" class="btn btn-sm btn-link text-decoration-none" style="font-size: 20px;">🌙</button>
                
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span style="color: var(--text-primary); font-size: 14px; font-weight: 500;">@User.Identity.Name</span>
                    <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius: 6px;">Logout</button>
                    </form>
                }
            </div>
        </header>

        <main role="main" class="p-4 pb-5">
            @RenderBody()
        </main>
        
        <footer class="mt-auto p-4 border-top" style="border-color: var(--border) !important;">
            <div class="text-center" style="color: var(--text-muted); font-size: 12px;">
                BlindMatch PAS &copy; 2026 | PUSL2020 Coursework
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>