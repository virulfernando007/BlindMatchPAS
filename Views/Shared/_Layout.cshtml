<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — BlindMatch PAS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
</head>
<body data-toast-success="@TempData["Success"]"
      data-toast-error="@TempData["Error"]">

    <!-- ── Navbar ─────────────────────────────────────────── -->
    <nav class="top-navbar">
        <div class="navbar-left">
            <button class="sidebar-toggle" id="sidebarToggle">&#9776;</button>
            <a href="/" class="nav-brand">
                BlindMatch<span class="brand-dot">.</span>PAS
            </a>
        </div>
        <div class="navbar-right">
            <button class="theme-toggle" id="themeToggle" title="Toggle theme">
                <span class="theme-icon-circle" id="themeIcon"></span>
            </button>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="nav-user">
                    <span class="nav-username">@User.Identity.Name?.Split('@')[0]</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout">Logout</button>
                    </form>
                </div>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn-nav-login">Login</a>
            }
        </div>
    </nav>

    <div class="app-layout">

        <!-- ── Sidebar ────────────────────────────────────── -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <aside class="sidebar" id="sidebar">
                <nav class="sidebar-nav">

                    @if (User.IsInRole("Student"))
                    {
                        <div class="nav-section-label">Student</div>
                        <a asp-controller="Student" asp-action="Dashboard"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Student" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                            <span class="nav-icon">⊞</span> Dashboard
                        </a>
                        <a asp-controller="Student" asp-action="Submit"
                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Submit" ? "active" : "")">
                            <span class="nav-icon">＋</span> Submit Proposal
                        </a>
                    }

                    @if (User.IsInRole("Supervisor"))
                    {
                        <div class="nav-section-label">Supervisor</div>
                        <a asp-controller="Supervisor" asp-action="Dashboard"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Supervisor" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                            <span class="nav-icon">⊞</span> Dashboard
                        </a>
                        <a asp-controller="Supervisor" asp-action="BlindReview"
                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "BlindReview" ? "active" : "")">
                            <span class="nav-icon">◎</span> Browse Projects
                        </a>
                        <a asp-controller="Supervisor" asp-action="ManageExpertise"
                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ManageExpertise" ? "active" : "")">
                            <span class="nav-icon">✦</span> My Expertise
                        </a>
                        <a asp-controller="Supervisor" asp-action="MatchedProjects"
                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MatchedProjects" ? "active" : "")">
                            <span class="nav-icon">✓</span> Matched Projects
                        </a>
                    }

                    @if (User.IsInRole("ModuleLeader"))
                    {
                        <div class="nav-section-label">Module Leader</div>
                        <a asp-controller="ModuleLeader" asp-action="Dashboard"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ModuleLeader" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                            <span class="nav-icon">⊞</span> Dashboard
                        </a>
                        <a asp-controller="ModuleLeader" asp-action="AllMatches"
                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AllMatches" ? "active" : "")">
                            <span class="nav-icon">⇄</span> All Matches
                        </a>
                        <a asp-controller="ModuleLeader" asp-action="ResearchAreas"
                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ResearchAreas" ? "active" : "")">
                            <span class="nav-icon">◈</span> Research Areas
                        </a>
                        <a asp-controller="ModuleLeader" asp-action="Analytics"
                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Analytics" ? "active" : "")">
                            <span class="nav-icon">◉</span> Analytics
                        </a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="nav-section-label">Admin</div>
                        <a asp-controller="Admin" asp-action="Dashboard"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                            <span class="nav-icon">⊞</span> Dashboard
                        </a>
                        <a asp-controller="Admin" asp-action="Users"
                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                            <span class="nav-icon">◎</span> Manage Users
                        </a>
                        <a asp-controller="Admin" asp-action="MigrationHistory"
                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MigrationHistory" ? "active" : "")">
                            <span class="nav-icon">◈</span> Migrations
                        </a>
                    }

                </nav>
            </aside>
        }

        <!-- ── Main Content ───────────────────────────────── -->
        <main class="main-content @(User.Identity?.IsAuthenticated == true ? "with-sidebar" : "")">
            @RenderBody()
        </main>

    </div>

    <!-- ── Toast Container ───────────────────────────────── -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- ── Footer ────────────────────────────────────────── -->
    <footer class="app-footer">
        BlindMatch PAS &copy; 2026 &nbsp;|&nbsp; PUSL2020 Coursework
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>