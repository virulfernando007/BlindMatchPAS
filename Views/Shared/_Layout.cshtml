<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlindMatch PAS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" integrity="sha512-QWcUTkXo/lhHvkVGI0dT0SJ3hj3i8nKLSLp4p/YaZXBv8FhZlA8vJZT6C3q0xjMw9vVqV5fCE3nZMp5kx1kQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
</head>
<body data-toast-success="@TempData["Success"]" data-toast-error="@TempData["Error"]">

    <nav class="sidebar">
        <div class="p-4">
            <a href="/" class="logo-text">BlindMatch<span class="logo-dot">.</span></a>
        </div>
        
        <div class="mt-4">
            @if (User.IsInRole("Admin"))
            {
                <div class="nav-section">
                    <div class="nav-section-label">Admin Controls</div>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Admin" asp-action="Dashboard">
                        <i class="fa-solid fa-gauge nav-icon"></i> Dashboard
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Users" ? "active" : "")" asp-controller="Admin" asp-action="Users">
                        <i class="fa-solid fa-users nav-icon"></i> Manage Users
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "MigrationHistory" ? "active" : "")" asp-controller="Admin" asp-action="MigrationHistory">
                        <i class="fa-solid fa-database nav-icon"></i> Migration History
                    </a>
                </div>
            }
            @if (User.IsInRole("Supervisor"))
            {
                <div class="nav-section">
                    <div class="nav-section-label">Supervision</div>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Supervisor" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Supervisor" asp-action="Dashboard">
                        <i class="fa-solid fa-gauge nav-icon"></i> Dashboard
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Supervisor" && ViewContext.RouteData.Values["Action"]?.ToString() == "BlindReview" ? "active" : "")" asp-controller="Supervisor" asp-action="BlindReview">
                        <i class="fa-solid fa-eye-slash nav-icon"></i> Blind Review
                    </a>
                </div>
            }
            @if (User.IsInRole("ModuleLeader"))
            {
                <div class="nav-section">
                    <div class="nav-section-label">Module Leadership</div>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ModuleLeader" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="ModuleLeader" asp-action="Dashboard">
                        <i class="fa-solid fa-gauge nav-icon"></i> Dashboard
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ModuleLeader" && ViewContext.RouteData.Values["Action"]?.ToString() == "Projects" ? "active" : "")" asp-controller="ModuleLeader" asp-action="Projects">
                        <i class="fa-solid fa-list nav-icon"></i> Projects
                    </a>
                </div>
            }
            @if (User.IsInRole("Student"))
            {
                <div class="nav-section">
                    <div class="nav-section-label">My Projects</div>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Student" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Student" asp-action="Dashboard">
                        <i class="fa-solid fa-gauge nav-icon"></i> Dashboard
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Student" && ViewContext.RouteData.Values["Action"]?.ToString() == "Submit" ? "active" : "")" asp-controller="Student" asp-action="Submit">
                        <i class="fa-solid fa-plus nav-icon"></i> Submit Project
                    </a>
                </div>
            }
        </div>
        </div>
    </nav>

    <div class="main-content with-sidebar">
        <header class="top-navbar">
            <div>
                </div>
            <div class="d-flex align-items-center gap-3">
                <button id="theme-toggle" class="theme-toggle" title="Toggle theme">
                    <i class="fa-solid fa-moon" style="font-size: 18px;"></i>
                </button>
                
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span style="color: var(--text-primary); font-size: 14px; font-weight: 500;">@User.Identity.Name</span>
                    <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="btn-sm btn-danger" style="margin: 0;">Logout</button>
                    </form>
                }
            </div>
        </header>

        <main role="main" class="p-4 pb-5">
            @RenderBody()
        </main>
        
        <footer class="mt-auto p-4 border-top" style="border-color: var(--border) !important;">
            <div class="text-center" style="color: var(--text-muted); font-size: 12px;">
                BlindMatch PAS &copy; 2026 | PUSL2020 Coursework
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>